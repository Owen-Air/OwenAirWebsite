---
const links = [
  { href: '/', label: 'Home' },
  { href: '/services', label: 'Services' },
  { href: '/about', label: 'About' },
  { href: '/contact', label: 'Contact' }
];

const pathname = Astro.url.pathname;
---

<header class="site-header">
  <div class="container header-inner">
    <a class="brand" href="/" aria-label="Owen Air Technical Services home">
      <span class="brand-mark" aria-hidden="true">OA</span>
      <span class="brand-text">
        <strong>Owen Air</strong>
        <small>Technical Services</small>
      </span>
    </a>

    <nav aria-label="Primary">
      <ul>
        {
          links.map((link) => {
            const isActive = pathname === link.href || (link.href !== '/' && pathname.startsWith(link.href));
            return (
              <li>
                <a href={link.href} aria-current={isActive ? 'page' : undefined}>
                  {link.label}
                </a>
              </li>
            );
          })
        }
      </ul>
    </nav>

    <a class="button button-primary header-cta" href="/contact">Request help</a>
  </div>
</header>

<style>
  .site-header {
    position: sticky;
    top: 0;
    z-index: 50;
    backdrop-filter: blur(10px);
    background: rgba(11, 17, 22, 0.78);
    border-bottom: 1px solid var(--line);
  }

  .header-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    min-height: 4rem;
  }

  .brand {
    display: flex;
    align-items: center;
    gap: 0.7rem;
    text-decoration: none;
  }

  .brand-mark {
    display: inline-grid;
    place-content: center;
    width: 2rem;
    height: 2rem;
    border-radius: 0.55rem;
    font-family: 'Sora', sans-serif;
    font-size: 0.82rem;
    color: #03131f;
    background: linear-gradient(135deg, var(--accent), #8de4ff);
  }

  .brand-text {
    display: grid;
    line-height: 1.05;
    color: var(--text);
  }

  .brand-text small {
    color: var(--text-muted);
    font-size: 0.73rem;
  }

  nav ul {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 0.3rem;
    list-style: none;
    margin: 0;
    padding: 0;
  }

  nav a {
    display: inline-flex;
    padding: 0.45rem 0.75rem;
    border-radius: 0.5rem;
    text-decoration: none;
    color: var(--text-muted);
    font-weight: 500;
  }

  nav a:hover,
  nav a:focus-visible,
  nav a[aria-current='page'] {
    color: var(--text);
    background: rgba(255, 255, 255, 0.04);
  }

  .header-cta {
    min-height: 2.55rem;
  }

  @media (max-width: 52rem) {
    .header-inner {
      padding-top: 0.6rem;
      padding-bottom: 0.6rem;
      flex-wrap: wrap;
    }

    nav {
      order: 3;
      width: 100%;
      overflow-x: auto;
    }

    nav ul {
      width: max-content;
      min-width: 100%;
      padding-bottom: 0.15rem;
    }

    .header-cta {
      margin-left: auto;
    }
  }
</style>

