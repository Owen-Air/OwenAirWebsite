---
interface Props {
  title: string;
  text: string;
  primary: { href: string; label: string };
  secondary?: { href: string; label: string };
}

const { title, text, primary, secondary } = Astro.props;
---

<section class="section">
  <div class="container">
    <div class="cta card">
      <div class="flow">
        <h2>{title}</h2>
        <p>{text}</p>
      </div>
      <div class="cta-actions">
        <a class="button button-primary" href={primary.href}>{primary.label}</a>
        {secondary && (
          <a class="button button-secondary" href={secondary.href}>{secondary.label}</a>
        )}
      </div>
    </div>
  </div>
</section>

<style>
  .cta {
    display: grid;
    gap: 1rem;
    align-items: center;
    grid-template-columns: 1fr auto;
    border: 1px solid rgba(87, 193, 255, 0.38);
    box-shadow: var(--shadow-lg);
    padding: 1.4rem;
  }

  h2 {
    margin: 0;
    font-family: 'Sora', sans-serif;
    font-size: clamp(1.4rem, 2.4vw, 2rem);
    line-height: 1.12;
  }

  p {
    margin: 0;
    color: var(--text-muted);
    max-width: 58ch;
  }

  .cta-actions {
    display: flex;
    flex-wrap: wrap;
    gap: 0.55rem;
    justify-content: flex-end;
  }

  @media (max-width: 52rem) {
    .cta {
      grid-template-columns: 1fr;
    }

    .cta-actions {
      justify-content: flex-start;
    }
  }
</style>
