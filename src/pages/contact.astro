---
import Layout from '../components/Layout.astro';
import ContactForm from '../components/ContactForm.astro';

const title = 'Contact Owen Air Technical Services';
const description =
  'Need help with IT, Wi-Fi, websites, AV, venue systems, van power or an awkward technical problem? Contact Owen Air Technical Services on the Isle of Man.';
---

<Layout title={title} description={description}>
  <section class="section">
    <div class="container grid grid-2">
      <article class="flow">
        <p class="pill">Contact</p>
        <h1 class="section-title">Tell me what you need</h1>
        <p class="section-lead">
          You do not need the right technical label. Describe what is happening and what a good outcome
          looks like — I will take it from there.
        </p>
        <ul class="check-list">
          <li>What is not working and how urgent it is</li>
          <li>Equipment, software or platforms involved</li>
          <li>What you have already tried</li>
        </ul>
      </article>

      <ContactForm />
    </div>
  </section>
</Layout>

<style>
  h1 {
    margin: 0;
  }
</style>
