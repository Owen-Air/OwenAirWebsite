---
import Layout from '../components/Layout.astro';
import Hero from '../components/Hero.astro';
import ServiceCard from '../components/ServiceCard.astro';
import CTASection from '../components/CTASection.astro';
import { services } from '../data/services';
import { caseStudies } from '../data/caseStudies';

const title = 'Owen Air Technical Services | IT, Websites, Wi-Fi, AV & Technical Help Isle of Man';
const description =
  'Practical technical help on the Isle of Man for IT support, UniFi networking, Astro/Cloudflare websites, AV systems, venue sound, van power and awkward technical problems.';

const featuredCaseStudy = caseStudies.find((study) => study.slug === 'the-outback') ?? caseStudies[0];

const ldJson = {
  '@context': 'https://schema.org',
  '@type': 'LocalBusiness',
  name: 'Owen Air Technical Services',
  areaServed: 'Isle of Man',
  url: 'https://owenair.im',
  description,
  serviceType: services.map((service) => service.title)
};
---

<Layout title={title} description={description}>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify(ldJson)}></script>
  </Fragment>

  <Hero
    compact
    eyebrow="Owen Air Technical Services · Isle of Man"
    title="Technical systems that need to work properly."
    subtitle="IT, UniFi networking, Astro websites, venue AV and van power — plus the awkward jobs that cross categories. Practical fixes, clear documentation."
    primaryCta={{ href: '/contact', label: 'Get in touch' }}
    secondaryCta={{ href: '/services', label: 'View services' }}
  />

  <section class="section" aria-labelledby="home-services-heading">
    <div class="container flow">
      <h2 class="section-title" id="home-services-heading">Services</h2>
      <p class="section-lead">
        Eight areas I work in. Most jobs cross boundaries — that is usually where I am most useful.
      </p>
      <div class="grid grid-3">
        {services.map((service) => (
          <ServiceCard
            title={service.title}
            description={service.shortDescription}
            href={`/services/${service.slug}`}
          />
        ))}
      </div>
    </div>
  </section>

  <section class="section" aria-labelledby="approach-heading">
    <div class="container">
      <article class="card approach-card flow">
        <h2 class="section-title" id="approach-heading">How I work</h2>
        <p class="section-lead">
          I look at the whole system before recommending anything — find the actual cause, fix what can be
          properly fixed, and leave you with something documented and maintainable.
        </p>
        <ul class="check-list approach-list">
          <li>Diagnose root causes, not just visible symptoms</li>
          <li>Reuse what is still good; stage upgrades when budget or risk requires it</li>
          <li>Plain-English explanations and practical handover notes</li>
          <li>Works across IT, networking, AV, web and power when problems overlap</li>
        </ul>
      </article>
    </div>
  </section>

  {featuredCaseStudy && (
    <section class="section" aria-labelledby="case-study-heading">
      <div class="container">
        <article class="card featured-case flow">
          <div class="case-meta">
            <p class="pill">Case study</p>
            {featuredCaseStudy.status === 'ongoing' && (
              <span class="status-badge">Ongoing</span>
            )}
          </div>
          <h2 class="section-title" id="case-study-heading">{featuredCaseStudy.title}</h2>
          <p class="section-lead">{featuredCaseStudy.summary}</p>
          <a class="button button-secondary" href={`/case-studies/${featuredCaseStudy.slug}`}>
            Read case study
          </a>
        </article>
      </div>
    </section>
  )}

  <CTASection
    title="Technical problem to sort?"
    text="Describe what is going wrong or what you want to build. Isle of Man based, practical and honest about next steps."
    primary={{ href: '/contact', label: 'Get in touch' }}
  />
</Layout>

<style>
  .approach-card {
    max-width: 44rem;
  }

  .approach-list {
    margin-top: 0.5rem;
  }

  .featured-case {
    max-width: 44rem;
  }

  .case-meta {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 0.5rem;
  }

  .status-badge {
    display: inline-block;
    padding: 0.12em 0.55em;
    font-size: 0.68rem;
    font-weight: 600;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    background: var(--accent-soft);
    color: var(--accent);
    border: 1px solid color-mix(in srgb, var(--accent) 30%, transparent);
    border-radius: 999px;
  }
</style>
