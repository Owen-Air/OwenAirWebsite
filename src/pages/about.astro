---
import Layout from '../components/Layout.astro';
import CTASection from '../components/CTASection.astro';

const title = 'About Owen Air | Isle of Man Technical Specialist';
const description =
  'About Owen Air: experienced, hands-on technical support across IT, websites, networking, AV systems and practical system design on the Isle of Man.';
---

<Layout title={title} description={description}>
  <section class="section">
    <div class="container grid grid-2">
      <article class="flow">
        <p class="pill">About</p>
        <h1 class="section-title">Experienced hands-on technical support, based on the Isle of Man</h1>
        <p class="section-lead">
          I am Owen Air. I help businesses, venues and individuals solve technical problems that are often
          cross-disciplinary: a mix of IT, networking, websites, AV and practical system design.
        </p>
      </article>

      <article class="card flow">
        <h2>How I work</h2>
        <ul class="check-list">
          <li>Diagnose first, then fix with a realistic plan</li>
          <li>Explain technical decisions in plain English</li>
          <li>Prefer reliable standards over gimmicks</li>
          <li>Design solutions that are supportable long term</li>
        </ul>
      </article>
    </div>
  </section>

  <section class="section">
    <div class="container grid grid-2">
      <article class="card flow">
        <h2>Breadth with technical depth</h2>
        <p>
          Many real problems do not stay in one lane. A network issue can involve power, cabling, device
          policy and poor documentation. A venue sound issue can involve DSP, patching and electrical layout.
        </p>
        <p>
          Working across domains means I can connect those dots quickly and avoid partial fixes that fail
          again later.
        </p>
      </article>

      <article class="card flow">
        <h2>Who I help</h2>
        <p>
          Small businesses, hospitality teams, venue operators, trades, and individuals who need practical
          technical work completed to a high standard.
        </p>
        <p>
          If your setup is messy or inherited, that is fine. Most good engineering starts from imperfect
          systems.
        </p>
      </article>
    </div>
  </section>

  <CTASection
    title="If your setup is complicated, that is exactly the point"
    text="Describe what is not working and what outcome you need. I will help you move from confusion to a practical fix."
    primary={{ href: '/contact', label: 'Request help' }}
    secondary={{ href: '/services', label: 'View services' }}
  />
</Layout>

<style>
  h1,
  h2 {
    margin: 0;
  }
</style>
