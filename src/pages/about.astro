---
import Layout from '../components/Layout.astro';
import CTASection from '../components/CTASection.astro';

const title = 'About Owen Air | Practical Technical Specialist Isle of Man';
const description =
  'Isle of Man based hands-on technical specialist working across IT support, networking, websites, AV systems, practical documentation and phased upgrades.';
---

<Layout title={title} description={description}>
  <section class="section">
    <div class="container grid grid-2">
      <article class="flow">
        <p class="pill">About</p>
        <h1 class="section-title">I like figuring out why things are not working and leaving them in a state that is easier to support</h1>
        <p class="section-lead">
          I am Owen Air, an Isle of Man based technical specialist. My background is IT, but most of the
          work I do crosses into networks, websites, venue AV, power systems and the gaps between all of
          those things.
        </p>
        <p class="section-lead">
          I have always been the person who wants to know how something is actually wired, why the fault
          only happens at certain times, and whether the fix being proposed is the right one or just the
          nearest available one.
        </p>
      </article>

      <article class="card flow">
        <h2>How I work</h2>
        <ul class="check-list">
          <li>I ask what problem you are actually trying to solve</li>
          <li>I review existing setup before recommending replacement</li>
          <li>I explain issues in plain English</li>
          <li>I prefer staged improvements where sensible</li>
          <li>I document important details</li>
          <li>I am honest when a specialist or certified person is needed</li>
        </ul>
      </article>
    </div>
  </section>

  <section class="section">
    <div class="container grid grid-2">
      <article class="card flow">
        <h2>What I spend most time on</h2>
        <p>
          IT support across Microsoft 365, Windows, devices and practical troubleshooting. UniFi networking
          for businesses and hospitality venues — guest isolation, VLANs, card machine separation and
          reliable Wi-Fi coverage.
        </p>
        <p>
          I also build Astro websites on Cloudflare, work on venue PA and AV systems, and help plan
          campervan power setups where a staged, safe approach matters.
        </p>
      </article>

      <article class="card flow">
        <h2>What the work usually looks like</h2>
        <p>
          A network with additions but no notes. A website that looks fine but does not generate enquiries.
          A sound system that is loud but not clear across the room. A van setup that needs a proper plan
          before the next piece of hardware goes in.
        </p>
        <p>
          I take those situations and work out what is actually going on before recommending anything.
          Where possible I leave documentation, so the next change is less risky.
        </p>
      </article>
    </div>
  </section>

  <CTASection
    title="If the setup is awkward, undocumented or just keeps going wrong, that is usually where I am most useful"
    text="Describe what is happening and what you want to achieve. I can tell you what I think is going on before any work is agreed."
    primary={{ href: '/contact', label: 'Tell me what you need' }}
    secondary={{ href: '/projects', label: 'See project-style examples' }}
  />
</Layout>

<style>
  h1,
  h2 {
    margin: 0;
  }
</style>
