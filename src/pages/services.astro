---
import Layout from '../components/Layout.astro';
import ServiceCard from '../components/ServiceCard.astro';
import CTASection from '../components/CTASection.astro';
import { services } from '../data/services';

const title = 'Technical Services | IT, Networking, Websites, AV & Van Power';
const description =
  'Explore practical technical services including IT support, UniFi networking, website development, AV/audio systems, van electrical planning and technical rescue.';
---

<Layout title={title} description={description}>
  <section class="section" aria-labelledby="services-page-heading">
    <div class="container flow">
      <p class="pill">Services</p>
      <h1 class="section-title" id="services-page-heading">Technical services</h1>
      <p class="section-lead">
        Pick a service for detail on what is covered, common problems and example work. If your job spans
        more than one area, start with Technical Rescue or just get in touch.
      </p>
      <div class="grid grid-3">
        {services.map((service) => (
          <ServiceCard
            title={service.title}
            description={service.shortDescription}
            href={`/services/${service.slug}`}
          />
        ))}
      </div>
    </div>
  </section>

  <CTASection
    title="Not sure which category applies?"
    text="Describe what is happening and I will work out what is actually going on."
    primary={{ href: '/contact', label: 'Get in touch' }}
  />
</Layout>

<style>
  h1 {
    margin: 0;
  }
</style>
